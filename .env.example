# Required — get a free cluster at https://mongodb.com/atlas
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/coderunner?retryWrites=true&w=majority

# Required — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace_with_a_long_random_string

# Set to "production" on Vercel (uses Piston API for code execution)
NODE_ENV=production

# Your deployed URL — used in canonical, Open Graph, sitemap, and robots.txt (no trailing slash)
PUBLIC_URL=https://your-app.vercel.app

# Optional — og-image.png should be placed in public/ for social sharing previews
# OG_IMAGE_PATH=public/og-image.png

# Optional — Vercel sets PORT automatically
PORT=3737
